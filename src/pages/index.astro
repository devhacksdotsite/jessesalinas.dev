---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Projects from '../components/Projects.astro';
import About from '../components/About.astro';
import Contact from '../components/Contact.astro';
---

<Base>
  <Nav />

  <!-- Horizontal slide wrapper: hero slides right, projects slides in from left -->
  <div id="horizontal-wrapper" class="relative h-screen overflow-hidden">
    <div id="horizontal-track" class="flex w-[200vw] h-screen">
      <div class="w-screen h-screen flex-shrink-0">
        <Hero />
      </div>
      <div class="w-screen h-screen flex-shrink-0">
        <Projects />
      </div>
    </div>
  </div>

  <!-- Floating scroll button -->
  <a id="scroll-arrow" class="fixed bottom-8 left-6 z-50 flex flex-col items-center gap-2 text-text-muted hover:text-accent transition-colors cursor-pointer opacity-0 pointer-events-none">
    <div id="scroll-icon-wrap" class="transition-transform duration-300">
      <svg class="w-4 h-4 animate-[bounce_2s_ease-in-out_infinite]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m0 0l-5-5m5 5l5-5" />
      </svg>
    </div>
    <span class="text-xs font-semibold uppercase tracking-widest" style="writing-mode: vertical-lr;">Scroll</span>
  </a>

  <!-- Remaining sections scroll normally -->
  <main>
    <About />
    <Contact />
  </main>

  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    const track = document.getElementById('horizontal-track')!;
    let stage: 'hero' | 'projects' | 'scrolling' = 'hero';
    let locked = false;

    // Force start at top on load/refresh
    window.history.scrollRestoration = 'manual';
    window.scrollTo(0, 0);
    if (window.location.hash) history.replaceState(null, '', window.location.pathname);
    document.body.style.overflow = 'hidden';

    function lock(ms = 600) { locked = true; setTimeout(() => { locked = false; }, ms); }
    const nav = (id: string) => (window as any).updateActiveNav?.(id);

    function slideToProjects() {
      if (stage !== 'hero' || locked) return;
      locked = true;
      stage = 'projects';
      nav('projects');
      gsap.to(track, {
        x: () => -window.innerWidth,
        duration: 0.8,
        ease: 'power3.inOut',
        onComplete: () => { lock(); updateArrow(); },
      });
    }

    function slideToHero() {
      if (stage !== 'projects' || locked) return;
      locked = true;
      stage = 'hero';
      nav('home');
      gsap.to(track, {
        x: 0,
        duration: 0.8,
        ease: 'power3.inOut',
        onComplete: () => { lock(); updateArrow(); },
      });
    }

    function enterScrolling() {
      if (stage !== 'projects' || locked) return;
      locked = true;
      stage = 'scrolling';
      document.body.style.overflow = '';
      // Small delay so refresh calculates correctly
      requestAnimationFrame(() => {
        ScrollTrigger.refresh();
        window.scrollTo({ top: window.innerHeight, behavior: 'smooth' });
        setTimeout(() => { locked = false; updateArrow(); }, 1000);
      });
    }

    // Wheel
    window.addEventListener('wheel', (e) => {
      if (locked) { e.preventDefault(); return; }

      if (stage === 'hero') {
        e.preventDefault();
        if (e.deltaY > 0) slideToProjects();
      } else if (stage === 'projects') {
        e.preventDefault();
        if (e.deltaY < 0) {
          slideToHero();
        } else if (e.deltaY > 0) {
          enterScrolling();
        }
      } else if (stage === 'scrolling' && e.deltaY < 0 && window.scrollY <= 0) {
        e.preventDefault();
        stage = 'projects';
        nav('projects');
        document.body.style.overflow = 'hidden';
        lock(400);
        updateArrow();
      }
    }, { passive: false });

    // Touch
    let touchStartY = 0;
    window.addEventListener('touchstart', (e) => { touchStartY = e.touches[0].clientY; }, { passive: true });
    window.addEventListener('touchend', (e) => {
      const delta = touchStartY - e.changedTouches[0].clientY;
      if (locked) return;
      if (stage === 'hero' && delta > 50) slideToProjects();
      else if (stage === 'projects' && delta < -50) slideToHero();
      else if (stage === 'projects' && delta > 50) enterScrolling();
    }, { passive: true });

    // Scroll CTA
    document.getElementById('scroll-cta')?.addEventListener('click', (e) => {
      e.preventDefault();
      slideToProjects();
    });

    // Scroll arrow
    const scrollArrow = document.getElementById('scroll-arrow')!;
    const scrollIconWrap = document.getElementById('scroll-icon-wrap')!;

    function updateArrow() {
      const hidden = stage === 'hero';
      scrollArrow.classList.toggle('opacity-0', hidden);
      scrollArrow.classList.toggle('pointer-events-none', hidden);
      scrollIconWrap.style.transform = stage === 'projects' ? '' : 'rotate(180deg)';
    }
    updateArrow();

    scrollArrow.addEventListener('click', () => {
      if (stage === 'hero') slideToProjects();
      else if (stage === 'projects') slideToHero();
      else if (stage === 'scrolling') {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });

    // Nav links
    document.querySelectorAll('a[href^="#"]').forEach((link) => {
      link.addEventListener('click', (e) => {
        const target = link.getAttribute('href')!.slice(1);

        if (target === 'home') {
          e.preventDefault();
          if (stage === 'scrolling') {
            stage = 'projects';
            nav('projects');
            document.body.style.overflow = 'hidden';
            window.scrollTo({ top: 0, behavior: 'instant' as ScrollBehavior });
          }
          if (stage === 'projects') slideToHero();
          updateArrow();
          return;
        }

        if (target === 'projects') {
          e.preventDefault();
          if (stage === 'hero') slideToProjects();
          else if (stage === 'scrolling') {
            stage = 'projects';
            nav('projects');
            document.body.style.overflow = 'hidden';
            window.scrollTo({ top: 0, behavior: 'instant' as ScrollBehavior });
          }
          updateArrow();
          return;
        }

        // About, Contact
        e.preventDefault();
        if (stage !== 'scrolling') {
          if (stage === 'hero') gsap.set(track, { x: -window.innerWidth });
          stage = 'scrolling';
          document.body.style.overflow = '';
          requestAnimationFrame(() => {
            ScrollTrigger.refresh();
            document.getElementById(target)?.scrollIntoView({ behavior: 'smooth' });
          });
        } else {
          document.getElementById(target)?.scrollIntoView({ behavior: 'smooth' });
        }
        updateArrow();
      });
    });
  </script>
</Base>
