---
---

<section id="home" class="min-h-screen flex items-center justify-center px-6">
  <div class="text-center">
    <div class="overflow-hidden">
      <h1 id="hero-name" class="text-5xl md:text-7xl font-bold mb-4 translate-y-full opacity-0">Jesse Salinas</h1>
    </div>
    <div class="text-xl md:text-2xl text-text-muted mb-2 h-8">
      <span id="typewriter"></span><span id="cursor" class="text-accent">|</span>
    </div>
    <div id="hero-links" class="flex justify-center gap-4 text-sm text-text-muted mt-6 opacity-0">
      <a href="#about" class="hover:text-accent transition-colors">About</a>
      <span>/</span>
      <a href="#projects" class="hover:text-accent transition-colors">Projects</a>
      <span>/</span>
      <a href="#contact" class="hover:text-accent transition-colors">Contact</a>
    </div>
    <a id="scroll-cta" href="#projects" class="inline-flex flex-col items-center gap-2 mt-12 text-text-muted hover:text-accent transition-colors opacity-0">
      <!-- Mouse scroll SVG -->
      <svg class="w-6 h-10" viewBox="0 0 24 40" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="1" y="1" width="22" height="38" rx="11" />
        <line class="mouse-wheel" x1="12" y1="8" x2="12" y2="14" stroke-linecap="round" />
      </svg>
      <span class="text-xs tracking-widest uppercase">Scroll Down</span>
    </a>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  const roles = [
    'Software Developer',
    'Full Stack Engineer',
    'Problem Solver',
    'Father of Four',
  ];

  // Slide up name
  gsap.to('#hero-name', { opacity: 1, y: 0, duration: 1, delay: 0.2, ease: 'power3.out' });

  // Typewriter
  const el = document.getElementById('typewriter')!;
  const cursor = document.getElementById('cursor')!;
  let roleIdx = 0;

  async function typeRole() {
    const text = roles[roleIdx];

    // Type
    for (let i = 0; i <= text.length; i++) {
      el.textContent = text.slice(0, i);
      await delay(80);
    }

    await delay(2000);

    // Delete
    for (let i = text.length; i >= 0; i--) {
      el.textContent = text.slice(0, i);
      await delay(40);
    }

    await delay(400);
    roleIdx = (roleIdx + 1) % roles.length;
    typeRole();
  }

  function delay(ms: number) {
    return new Promise((r) => setTimeout(r, ms));
  }

  // Cursor blink
  gsap.to(cursor, { opacity: 0, repeat: -1, yoyo: true, duration: 0.5, ease: 'steps(1)' });

  // Stagger in links + CTA
  gsap.to('#hero-links', { opacity: 1, duration: 0.6, delay: 0.6 });
  gsap.to('#scroll-cta', { opacity: 1, duration: 0.6, delay: 0.9 });

  // Mouse wheel animation
  gsap.to('.mouse-wheel', {
    y: 6,
    opacity: 0,
    repeat: -1,
    duration: 1,
    ease: 'power1.in',
    repeatDelay: 0.5,
  });

  typeRole();
</script>
