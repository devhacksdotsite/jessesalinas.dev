---
const techStack = [
  {
    label: 'Backend',
    items: ['Node.js (Express.js)', 'PHP', 'Perl (Mojolicious)', 'Python', 'ColdFusion (Lucee5)', 'WordPress', 'Strapi'],
  },
  {
    label: 'Frontend',
    items: ['HTML', 'CSS', 'SCSS', 'JavaScript', 'ReactJS', 'Vue', 'Vuex', 'Svelte', 'Next.js', 'Tailwind', 'Bootstrap', 'MaterialUI', 'Vuetify', 'jQuery'],
  },
  {
    label: 'Database',
    items: ['MySQL', 'MariaDB'],
  },
  {
    label: 'Tools / Other',
    items: ['Docker', 'AWS (S3, EC2, RDS)', 'REST', 'cURL', 'Git', 'TFS', 'Linux', 'Nginx', 'Apache', 'Tmux', 'Vim', 'Webpack', 'Gulp', 'GTM', 'Livekit'],
  },
];
---

<section id="about" class="py-24 px-6 bg-bg-secondary">
  <div class="max-w-6xl mx-auto">
    <div class="overflow-hidden">
      <h2 class="section-heading text-4xl font-bold mb-12 translate-y-full">About Me</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-12">
      <!-- Bio -->
      <div class="about-block">
        <div class="flex flex-wrap gap-x-8 gap-y-2 text-sm text-text-muted mb-6">
          <span><span class="text-text font-medium">Location:</span> Sunny Arizona</span>
          <span><span class="text-text font-medium">Languages:</span> English, Spanish</span>
        </div>

        <div class="space-y-4 text-text-muted leading-relaxed">
          <p>
            Hi, my name is Jesse. I am a passionate Software Developer and a proud father of four beautiful children. Over the years, I have immersed myself in the world of coding, with a particular focus on web development.
          </p>
          <p>
            I have a strong command of both frontend and backend development, and I am capable of creating clean and functional full-stack applications and systems. Whether you're looking for collaboration on a project or seeking someone to work on your next endeavor, feel free to reach out.
          </p>
        </div>
      </div>

      <!-- Tech Stack -->
      <div class="about-block space-y-6">
        <h3 class="text-lg font-semibold">Tech Stack</h3>
        {techStack.map(({ label, items }) => (
          <div>
            <h4 class="text-sm font-medium text-accent mb-2">{label}</h4>
            <div class="flex flex-wrap gap-2">
              {items.map((item) => (
                <span class="text-xs px-2 py-1 rounded bg-border/50 text-text-muted">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Heading reveal
  gsap.to('#about .section-heading', {
    scrollTrigger: { trigger: '#about', start: 'top 80%' },
    y: 0,
    duration: 0.8,
    ease: 'power3.out',
  });

  gsap.from('.about-block', {
    scrollTrigger: { trigger: '#about', start: 'top 80%' },
    opacity: 0,
    y: 30,
    stagger: 0.2,
    duration: 0.6,
  });
</script>
