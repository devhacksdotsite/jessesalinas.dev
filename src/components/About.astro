---
const techStack = [
  {
    label: 'Backend',
    items: ['Node.js (Express.js)', 'PHP', 'Perl (Mojolicious)', 'Python', 'ColdFusion (Lucee 5)', 'WordPress', 'Strapi'],
  },
  {
    label: 'Frontend',
    items: ['HTML', 'CSS', 'SCSS', 'JavaScript', 'TypeScript', 'React', 'Vue', 'Vuex', 'PrimeVue', 'Svelte', 'Next.js', 'Astro', 'Tailwind CSS', 'Bootstrap', 'Material UI', 'Vuetify', 'jQuery'],
  },
  {
    label: 'Database',
    items: ['MySQL', 'MariaDB', 'Amazon Aurora', 'DynamoDB'],
  },
  {
    label: 'Cloud / DevOps',
    items: ['AWS (S3, EC2, RDS, CloudFront)', 'Docker', 'Linux (Ubuntu)', 'Nginx', 'Apache'],
  },
  {
    label: 'Tools / Other',
    items: ['REST APIs', 'cURL', 'Git', 'TFS', 'Tmux', 'Vim', 'Webpack', 'Gulp', 'Google Tag Manager (GTM)', 'LiveKit', 'Mermaid', 'TSDoc'],
  },
];

const credentials = [
  {
    label: 'Security Clearance',
    items: ['U.S. Department of Homeland Security (DHS) Clearance (active)'],
  },
];
---

<section id="about" class="py-24 px-6 bg-bg-secondary">
  <div class="max-w-6xl mx-auto">
    <div class="overflow-hidden">
      <h2 class="section-heading text-4xl font-bold mb-12 translate-y-full">About Me</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-12">
      <!-- Bio -->
      <div class="about-block">
        <div class="flex flex-wrap gap-x-8 gap-y-2 text-sm text-text-muted mb-6">
          <span><span class="text-text font-medium">Location:</span> Always Sunny Arizona</span>
          <span><span class="text-text font-medium">Languages:</span> English, Spanish</span>
        </div>

        <div class="space-y-4 text-text-muted leading-relaxed">
          <p>
            Hi, I'm Jesse! I'm a software engineer focused on building scalable web applications and systems. I specialize in full-stack development and have experience taking products through the entire lifecycle: from architecture and system design to development, deployment, and ongoing operations.
          </p>
          <p>
            I enjoy creating clean, maintainable solutions and designing systems that are reliable, efficient, and built to grow. I'm always open to collaborating on projects or helping bring new ideas to life.
          </p>
        </div>
      </div>

      <!-- Tech Stack -->
      <div class="about-block space-y-6">
        <h3 class="text-lg font-semibold">Tech Stack</h3>
        {techStack.map(({ label, items }) => (
          <div>
            <h4 class="text-sm font-medium text-accent mb-2">{label}</h4>
            <div class="flex flex-wrap gap-2">
              {items.map((item) => (
                <span class="text-xs px-2 py-1 rounded bg-border/50 text-text-muted">{item}</span>
              ))}
            </div>
          </div>
        ))}

        {credentials.map(({ label, items }) => (
          <div>
            <h4 class="text-sm font-medium text-accent mb-2">{label}</h4>
            <div class="flex flex-wrap gap-2">
              {items.map((item) => (
                <span class="text-xs px-2 py-1 rounded bg-accent/15 text-accent">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Heading reveal
  gsap.to('#about .section-heading', {
    scrollTrigger: { trigger: '#about', start: 'top 80%' },
    y: 0,
    duration: 0.8,
    ease: 'power3.out',
  });

  gsap.fromTo('.about-block',
    { opacity: 0, y: 30 },
    {
      scrollTrigger: { trigger: '#about', start: 'top 80%', toggleActions: 'play none none reset' },
      opacity: 1,
      y: 0,
      stagger: 0.2,
      duration: 0.6,
    },
  );
</script>
