---
const techStack = [
  {
    label: 'Backend',
    items: ['Node.js (Express.js)', 'PHP', 'Perl (Mojolicious)', 'Python (FastAPI)', 'ColdFusion (Lucee 5)', 'WordPress', 'Strapi'],
  },
  {
    label: 'Frontend',
    items: ['HTML', 'CSS', 'SCSS', 'JavaScript', 'TypeScript', 'React', 'Vue', 'Vuex', 'PrimeVue', 'Svelte', 'Next.js', 'Astro', 'Tailwind CSS', 'Bootstrap', 'Material UI', 'Vuetify', 'jQuery'],
  },
  {
    label: 'Database',
    items: ['MySQL', 'MariaDB', 'PostgreSQL', 'Amazon Aurora', 'DynamoDB'],
  },
  {
    label: 'Cloud / DevOps',
    items: ['AWS', 'Digital Ocean', 'Docker', 'Linux (Ubuntu)', 'Nginx', 'Apache'],
  },
  {
    label: 'Tools / Other',
    items: ['REST APIs', 'cURL', 'Git', 'TFS', 'Tmux', 'Vim', 'Webpack', 'Gulp', 'Google Tag Manager (GTM)', 'LiveKit', 'Mermaid', 'TSDoc', 'Pydantic', 'SQLAlchemy'],
  },
  {
    label: 'Testing',
    items: ['Vitest', 'Jest', 'Playwright', 'Storybook', 'pytest'],
  },
];

const credentials = [
  {
    label: 'Security Clearance',
    items: ['U.S. Department of Homeland Security (DHS) Clearance (active)'],
  },
  {
    label: 'AWS Certifications',
    items: ['AWS Certified Cloud Practitioner (CLF-C02) (active)'],
  },
];
---

<section id="about" class="py-24 px-6 bg-bg-secondary relative overflow-hidden">
  <!-- Floating tech cloud background (left side) -->
  <div id="about-tech-cloud" class="absolute inset-0 pointer-events-none">
    <div id="about-cloud-inner" class="relative w-full h-full">
      {['Node.js','React','Vue','TypeScript','Python','Docker','AWS','MySQL','Tailwind','Express','Next.js','Astro','PHP','Nginx','Git','Linux','Svelte','PrimeVue','Vitest','Playwright'].map((name, i) => {
        const angle = (i / 20) * Math.PI * 2;
        const radius = 18 + (i % 3) * 12;
        const x = 22 + Math.cos(angle) * radius;
        const y = 50 + Math.sin(angle) * radius;
        const size = [0.6, 0.7, 0.8, 0.65, 0.75][i % 5];
        const opacity = [0.08, 0.12, 0.06, 0.1, 0.07][i % 5];
        return <span class="about-tech-word absolute text-accent font-semibold whitespace-nowrap" style={`left:${x}%;top:${y}%;font-size:${size}rem;opacity:${opacity};transform:translate(-50%,-50%);`}>{name}</span>
      })}
    </div>
  </div>

  <div class="max-w-6xl mx-auto relative z-10">
    <div class="overflow-hidden">
      <h2 class="section-heading text-4xl font-bold mb-12 translate-y-full">About Me</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-12">
      <!-- Bio -->
      <div class="about-block">
        <div class="flex flex-wrap gap-x-8 gap-y-2 text-sm text-text-muted mb-6">
          <span><span class="text-text font-medium">Location:</span> Always Sunny Arizona</span>
          <span><span class="text-text font-medium">Languages:</span> English, Spanish</span>
        </div>

        <div class="space-y-4 text-text-muted leading-relaxed">
          <p>
            Hi, I'm Jesse! I'm a software engineer focused on building scalable web applications and systems. I specialize in full-stack development and have experience taking products through the entire lifecycle: from architecture and system design to development, deployment, and ongoing operations.
          </p>
          <p>
            I enjoy creating clean, maintainable solutions and designing systems that are reliable, efficient, and built to grow. I'm always open to collaborating on projects or helping bring new ideas to life.
          </p>
        </div>
      </div>

      <!-- Tech Stack -->
      <div class="about-block space-y-6">
        <h3 class="text-lg font-semibold">Tech Stack</h3>
        {techStack.map(({ label, items }) => (
          <div>
            <h4 class="text-sm font-medium text-accent mb-2">{label}</h4>
            <div class="flex flex-wrap gap-2">
              {items.map((item) => (
                <span class="text-xs px-2 py-1 rounded bg-border/50 text-text-muted">{item}</span>
              ))}
            </div>
          </div>
        ))}

        {credentials.map(({ label, items }) => (
          <div>
            <h4 class="text-sm font-medium text-accent mb-2">{label}</h4>
            <div class="flex flex-wrap gap-2">
              {items.map((item) => (
                <span class="text-xs px-2 py-1 rounded bg-accent/15 text-accent">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Heading reveal
  gsap.to('#about .section-heading', {
    scrollTrigger: { trigger: '#about', start: 'top 80%' },
    y: 0,
    duration: 0.8,
    ease: 'power3.out',
  });

  gsap.fromTo('.about-block',
    { opacity: 0, y: 30 },
    {
      scrollTrigger: { trigger: '#about', start: 'top 80%', toggleActions: 'play none none reset' },
      opacity: 1,
      y: 0,
      stagger: 0.2,
      duration: 0.6,
    },
  );

  // About tech cloud animation
  const aboutCloud = document.getElementById('about-cloud-inner');
  if (aboutCloud) {
    const cloudRotation = { angle: 0 };
    gsap.to(cloudRotation, {
      angle: 25,
      duration: 80,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut',
      onUpdate: () => {
        aboutCloud.style.transform = `rotate(${cloudRotation.angle}deg)`;
      },
    });

    document.querySelectorAll('.about-tech-word').forEach((word) => {
      gsap.to(word, {
        y: `+=${4 + Math.random() * 10}`,
        x: `+=${-6 + Math.random() * 12}`,
        duration: 2.5 + Math.random() * 4,
        repeat: -1,
        yoyo: true,
        ease: 'sine.inOut',
        delay: Math.random() * 3,
      });
      gsap.to(word, {
        opacity: parseFloat((word as HTMLElement).style.opacity) * (0.4 + Math.random() * 1.2),
        duration: 2 + Math.random() * 5,
        repeat: -1,
        yoyo: true,
        ease: 'sine.inOut',
        delay: Math.random() * 4,
      });
    });
  }
</script>
