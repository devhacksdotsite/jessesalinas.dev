---

<section id="contact" class="py-24 px-6">
  <div class="max-w-6xl mx-auto text-center">
    <h2 id="contact-heading" class="text-4xl font-bold mb-4">Get in touch</h2>
    <p class="text-text-muted mb-8">Have a project in mind? Let's work together.</p>
    <a
      id="contact-cta"
      href="mailto:inquire@jessesalinas.dev?subject=Hey Jesse, let's work together!"
      class="inline-block px-8 py-3 rounded-full border border-accent text-accent hover:bg-accent hover:text-white transition-all duration-300 text-lg"
    >
      inquire@jessesalinas.dev
    </a>
  </div>
</section>

<footer class="py-6 text-center text-text-muted text-xs border-t border-border">
  &copy; {new Date().getFullYear()} Jesse Salinas
</footer>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('#contact-heading, #contact-cta', {
    scrollTrigger: { trigger: '#contact', start: 'top 80%' },
    opacity: 0,
    y: 20,
    stagger: 0.15,
    duration: 0.5,
  });
</script>
